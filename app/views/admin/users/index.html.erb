<% content_for :title, t('.title') %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold"><%= t('.title') %></h1>
</div>

<!-- Filters -->
<div class="bg-white rounded-lg shadow p-4 mb-6">
  <%= form_with url: admin_users_path, method: :get, class: "flex gap-4" do |f| %>
    <%= f.text_field :search, placeholder: t('.search_placeholder'), value: params[:search], class: "border rounded px-3 py-2 flex-1" %>
    <%= f.select :role, options_for_select([
        [t('.all_roles'), ""],
        [t('.user_role'), "user"],
        [t('.admin_role'), "admin"]
      ], params[:role]), {}, class: "border rounded px-3 py-2" %>
    <%= f.submit t('.search_btn'), class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
  <% end %>
</div>

<!-- Users Table -->
<div class="bg-white rounded-lg shadow overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_user') %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_email') %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_role') %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_family') %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_joined') %></th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase"><%= t('.col_actions') %></th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @users.each do |user| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="font-medium text-gray-900"><%= user.name %></div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= user.email %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= user.admin? ? 'bg-purple-100 text-purple-800' : 'bg-green-100 text-green-800' %>">
              <%= user.role.titleize %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if user.family_account.present? %>
              <%= user.family_account.name || t('.col_family') %>
            <% else %>
              <span class="text-gray-400"><%= t('.no_family') %></span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <%= t('.ago', time: time_ago_in_words(user.created_at)) %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <%= link_to t('.view'), admin_user_path(user), class: "text-blue-600 hover:underline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @users.empty? %>
  <div class="text-center py-12 text-gray-500">
    <%= t('.no_users') %>
  </div>
<% end %>
