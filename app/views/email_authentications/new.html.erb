<h1><%= t('.title') %></h1>

<% if flash[:alert] %>
  <p><%= flash[:alert] %></p>
<% else %>
  <p><%= t('.intro') %></p>
<% end %>

<%= form_with url: create_url, data: { turbo: false } do |f| %>
  <div>
    <%= f.label :email, t('.email_label') %>
    <%= f.email_field :email, name: "nopassword_email_authentication[email]", value: @authentication.email, autofocus: true, autocomplete: "email" %>
  </div>

  <% if @authentication.errors[:email].any? %>
    <p><%= @authentication.errors[:email].to_sentence %></p>
  <% end %>

  <%= f.submit t('.submit') %>
<% end %>
