<!-- Animated Background Container -->
<div class="landing-animation-container" data-controller="landing-animation" data-landing-animation-scene-count-value="3">
  <!-- Scene 1 -->
  <div class="animation-scene active" data-landing-animation-target="scene">
    <div class="drawing-layer sketch-layer scene-gradient-1">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white/20 text-9xl font-bold transform rotate-12">✏️</div>
      </div>
    </div>
    <div class="drawing-layer rendered-layer scene-gradient-1">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white text-9xl transform">✨</div>
      </div>
    </div>
  </div>

  <!-- Scene 2 -->
  <div class="animation-scene hidden" data-landing-animation-target="scene">
    <div class="drawing-layer sketch-layer scene-gradient-2">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white/20 text-9xl font-bold transform -rotate-6">🎨</div>
      </div>
    </div>
    <div class="drawing-layer rendered-layer scene-gradient-2">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white text-9xl">🌟</div>
      </div>
    </div>
  </div>

  <!-- Scene 3 -->
  <div class="animation-scene hidden" data-landing-animation-target="scene">
    <div class="drawing-layer sketch-layer scene-gradient-3">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white/20 text-9xl font-bold transform rotate-6">📖</div>
      </div>
    </div>
    <div class="drawing-layer rendered-layer scene-gradient-3">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-white text-9xl">📚</div>
      </div>
    </div>
  </div>

  <!-- Page Turn Effect -->
  <div class="page-turn-container">
    <div class="page-turn" data-landing-animation-target="page"></div>
  </div>
</div>

<!-- Main Content (overlays the animation) -->
<div class="landing-content min-h-screen">
  <!-- Hero Section -->
  <div class="relative min-h-screen flex items-center">
    <div class="absolute inset-0 bg-black/20 backdrop-blur-sm"></div>

    <div class="container mx-auto px-4 py-16 relative z-10">
      <!-- Header/Navigation -->
      <div class="flex justify-between items-center mb-16">
        <div class="flex items-center space-x-2">
          <%= icon "book-open", class: "w-8 h-8 text-white" %>
          <span class="text-2xl font-bold text-white"><%= t(".brand") %></span>
        </div>
        <div class="flex space-x-4">
          <%= link_to t(".log_in"), login_path, class: "text-white hover:text-gray-200 transition" %>
          <%= link_to t(".sign_up"), signup_path, class: "bg-white text-purple-600 px-6 py-2 rounded-lg font-semibold hover:bg-gray-100 transition" %>
        </div>
      </div>

      <!-- Hero Content -->
      <div class="max-w-4xl mx-auto text-center text-white">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 drop-shadow-lg">
          <%= t(".hero_title") %>
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-white/90 drop-shadow">
          <%= t(".hero_subtitle") %>
        </p>

        <!-- Email Signup Form -->
        <div class="max-w-md mx-auto bg-white/95 backdrop-blur rounded-2xl shadow-2xl p-8">
          <%= form_with url: onboarding_start_path, method: :post, class: "space-y-4" do |f| %>
            <div>
              <%= f.label :email, t(".cta_label"), class: "block text-gray-800 font-bold mb-3 text-xl" %>
              <%= f.email_field :email, required: true, placeholder: t(".cta_email_placeholder"),
                  class: "w-full px-4 py-4 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent text-gray-800 text-lg",
                  autofocus: true %>
            </div>
            <%= f.submit t(".cta_submit"), class: "w-full bg-gradient-to-r from-purple-600 to-blue-600 text-white font-bold py-4 px-6 rounded-lg hover:from-purple-700 hover:to-blue-700 transition duration-200 cursor-pointer text-lg shadow-lg" %>
            <p class="text-sm text-gray-600 text-center">
              <%= t(".cta_disclaimer") %>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Simple Illustration Section -->
  <div class="bg-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="flex justify-center">
          <div class="simple-illustration">
            <div class="w-full h-full bg-gradient-to-br from-yellow-400 via-orange-400 to-pink-500 rounded-3xl flex items-center justify-center transform hover:scale-105 transition duration-300 shadow-2xl">
              <div class="text-white text-8xl">🎨</div>
            </div>
          </div>
        </div>
        <div class="text-gray-800">
          <h2 class="text-4xl font-bold mb-6"><%= t(".illustration_title") %></h2>
          <p class="text-xl text-gray-600 mb-4">
            <%= t(".illustration_body_1") %>
          </p>
          <p class="text-xl text-gray-600">
            <%= t(".illustration_body_2") %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Grid -->
  <div class="bg-gradient-to-br from-purple-500 via-blue-500 to-teal-500 py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-center text-white mb-12"><%= t(".features_title") %></h2>
      <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 text-white transform hover:scale-105 transition duration-300">
          <div class="bg-white/20 w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
            <%= icon "sparkles", class: "w-8 h-8" %>
          </div>
          <h3 class="text-2xl font-bold mb-3"><%= t(".feature_1_title") %></h3>
          <p class="text-white/90 text-lg">
            <%= t(".feature_1_body") %>
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 text-white transform hover:scale-105 transition duration-300">
          <div class="bg-white/20 w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
            <%= icon "image", class: "w-8 h-8" %>
          </div>
          <h3 class="text-2xl font-bold mb-3"><%= t(".feature_2_title") %></h3>
          <p class="text-white/90 text-lg">
            <%= t(".feature_2_body") %>
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-8 text-white transform hover:scale-105 transition duration-300">
          <div class="bg-white/20 w-16 h-16 rounded-2xl flex items-center justify-center mb-6">
            <%= icon "book-heart", class: "w-8 h-8" %>
          </div>
          <h3 class="text-2xl font-bold mb-3"><%= t(".feature_3_title") %></h3>
          <p class="text-white/90 text-lg">
            <%= t(".feature_3_body") %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Another Simple Illustration Section -->
  <div class="bg-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <div class="text-gray-800 order-2 md:order-1">
          <h2 class="text-4xl font-bold mb-6"><%= t(".grows_title") %></h2>
          <p class="text-xl text-gray-600 mb-4">
            <%= t(".grows_body_1") %>
          </p>
          <p class="text-xl text-gray-600">
            <%= t(".grows_body_2") %>
          </p>
        </div>
        <div class="flex justify-center order-1 md:order-2">
          <div class="simple-illustration">
            <div class="w-full h-full bg-gradient-to-br from-blue-400 via-purple-500 to-pink-500 rounded-3xl flex items-center justify-center transform hover:scale-105 transition duration-300 shadow-2xl">
              <div class="text-white text-8xl">📚</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Benefits Section -->
  <div class="bg-gradient-to-br from-teal-500 via-blue-500 to-purple-500 py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-center text-white mb-12"><%= t(".benefits_title") %></h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="flex items-start space-x-4 bg-white/10 backdrop-blur-lg rounded-xl p-6">
            <%= icon "circle-check", class: "w-8 h-8 flex-shrink-0 mt-1 text-white" %>
            <div class="text-white">
              <h4 class="font-bold text-xl mb-2"><%= t(".benefit_1_title") %></h4>
              <p class="text-white/90"><%= t(".benefit_1_body") %></p>
            </div>
          </div>
          <div class="flex items-start space-x-4 bg-white/10 backdrop-blur-lg rounded-xl p-6">
            <%= icon "circle-check", class: "w-8 h-8 flex-shrink-0 mt-1 text-white" %>
            <div class="text-white">
              <h4 class="font-bold text-xl mb-2"><%= t(".benefit_2_title") %></h4>
              <p class="text-white/90"><%= t(".benefit_2_body") %></p>
            </div>
          </div>
          <div class="flex items-start space-x-4 bg-white/10 backdrop-blur-lg rounded-xl p-6">
            <%= icon "circle-check", class: "w-8 h-8 flex-shrink-0 mt-1 text-white" %>
            <div class="text-white">
              <h4 class="font-bold text-xl mb-2"><%= t(".benefit_3_title") %></h4>
              <p class="text-white/90"><%= t(".benefit_3_body") %></p>
            </div>
          </div>
          <div class="flex items-start space-x-4 bg-white/10 backdrop-blur-lg rounded-xl p-6">
            <%= icon "circle-check", class: "w-8 h-8 flex-shrink-0 mt-1 text-white" %>
            <div class="text-white">
              <h4 class="font-bold text-xl mb-2"><%= t(".benefit_4_title") %></h4>
              <p class="text-white/90"><%= t(".benefit_4_body") %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- How It Works -->
  <div class="bg-white py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-gray-800 mb-12"><%= t(".how_title") %></h2>
        <div class="grid md:grid-cols-4 gap-8">
          <div class="transform hover:scale-105 transition duration-300">
            <div class="bg-gradient-to-br from-purple-500 to-blue-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold text-white shadow-lg">
              1
            </div>
            <h4 class="font-bold text-xl mb-2 text-gray-800"><%= t(".step_1_title") %></h4>
            <p class="text-gray-600"><%= t(".step_1_body") %></p>
          </div>
          <div class="transform hover:scale-105 transition duration-300">
            <div class="bg-gradient-to-br from-blue-500 to-teal-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold text-white shadow-lg">
              2
            </div>
            <h4 class="font-bold text-xl mb-2 text-gray-800"><%= t(".step_2_title") %></h4>
            <p class="text-gray-600"><%= t(".step_2_body") %></p>
          </div>
          <div class="transform hover:scale-105 transition duration-300">
            <div class="bg-gradient-to-br from-teal-500 to-green-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold text-white shadow-lg">
              3
            </div>
            <h4 class="font-bold text-xl mb-2 text-gray-800"><%= t(".step_3_title") %></h4>
            <p class="text-gray-600"><%= t(".step_3_body") %></p>
          </div>
          <div class="transform hover:scale-105 transition duration-300">
            <div class="bg-gradient-to-br from-green-500 to-purple-500 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl font-bold text-white shadow-lg">
              4
            </div>
            <h4 class="font-bold text-xl mb-2 text-gray-800"><%= t(".step_4_title") %></h4>
            <p class="text-gray-600"><%= t(".step_4_body") %></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Final CTA Section -->
  <div class="bg-gradient-to-br from-purple-600 via-blue-600 to-teal-600 py-20">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-5xl font-bold text-white mb-6"><%= t(".final_cta_title") %></h2>
      <p class="text-2xl text-white/90 mb-8"><%= t(".final_cta_body") %></p>
      <%= link_to t(".final_cta_link"), onboarding_start_path, method: :post, class: "inline-block bg-white text-purple-600 px-12 py-4 rounded-full font-bold text-xl hover:bg-gray-100 transition duration-200 shadow-2xl transform hover:scale-105" %>
    </div>
  </div>

  <!-- Footer -->
  <div class="bg-gray-900 text-white">
    <div class="container mx-auto px-4 py-8 text-center">
      <p class="text-gray-400">
        <%= t(".footer") %>
      </p>
    </div>
  </div>
</div>
