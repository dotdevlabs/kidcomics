<div class="min-h-screen bg-gray-50 flex items-center justify-center">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12 text-center">
    <div class="bg-white rounded-lg shadow-md p-12">
      <div class="mb-6">
        <%= icon "camera", class: "w-20 h-20 mx-auto text-purple-600" %>
      </div>

      <h1 class="text-3xl font-bold text-gray-800 mb-4"><%= t('books_views.new.title') %></h1>

      <p class="text-lg text-gray-600 mb-6">
        <%= t('books_views.new.body') %>
      </p>

      <p class="text-gray-500">
        <%= t('books_views.new.redirect_html', link: link_to(t('books_views.new.redirect_link'), child_profile_books_path(@child_profile), class: "text-purple-600 hover:text-purple-700 underline")).html_safe %>
      </p>
    </div>
  </div>
</div>
